{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cpfbackend-se-asia.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://cpfbackend-se-asia.onrender.com/health"
    },
    {
      "source": "/((?!api/|health).*)",
      "destination": "/index.html"
    }
  ]
}
